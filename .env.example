# EuroPeptiva — Variables de entorno
# Copia este archivo a .env y rellena los valores

# Django
SECRET_KEY=cambia-esto-por-un-valor-largo-y-aleatorio
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (SQLite en local, PostgreSQL en producción)
# En producción descomenta DATABASE_URL:
# DATABASE_URL=postgres://europeptiva:password@localhost/europeptiva

# Email — en local imprime a consola, en prod usa Gmail o Mailjet
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para Gmail App Password:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password-de-16-caracteres
DEFAULT_FROM_EMAIL=EuroPeptiva <noreply@europeptiva.com>
ADMIN_EMAIL=pepepablopaco@gmail.com

# Transferencia bancaria (aparece en emails de confirmación de pedido)
BANK_IBAN=ES00 0000 0000 0000 0000 0000
BANK_HOLDER=Nombre Apellido (o razón social del autónomo)

# Mollie — pagos con tarjeta (opcional en el lanzamiento)
# MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Datos fiscales del titular — aparecen en el aviso legal y la política de privacidad.
# Mientras alguno lleve corchetes, las páginas legales muestran un aviso de "pendiente".
LEGAL_NAME=Nombre Apellido (o razón social)
LEGAL_NIF=00000000X
LEGAL_ADDRESS=Calle Ejemplo 1, 2º B
LEGAL_POSTCODE=28001
LEGAL_CITY=Madrid
LEGAL_EMAIL=info@europeptiva.com
